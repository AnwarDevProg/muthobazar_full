rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function adminPermissionDoc() {
      return /databases/(default)/documents/admin_permissions/$(request.auth.uid);
    }

    function hasAdminPermissionDoc() {
      return signedIn() && firestore.exists(adminPermissionDoc());
    }

    function adminPermission() {
      return firestore.get(adminPermissionDoc()).data;
    }

    function isSuperAdmin() {
      return hasAdminPermissionDoc() && adminPermission().role == 'super_admin';
    }

    function canManageCategories() {
      return hasAdminPermissionDoc() && adminPermission().canManageCategories == true;
    }

    function canManageBrands() {
      return hasAdminPermissionDoc() && adminPermission().canManageBrands == true;
    }

    function canManageBanners() {
      return hasAdminPermissionDoc() && adminPermission().canManageBanners == true;
    }

    function canManageProducts() {
      return hasAdminPermissionDoc() && adminPermission().canManageProducts == true;
    }

    match /profile_pictures/{userId}/{fileName} {
      allow read: if true;
      allow write: if signedIn() && request.auth.uid == userId;
    }

    match /product_images/{productId}/{fileName} {
      allow read: if true;
      allow write: if canManageProducts() || isSuperAdmin();
    }

    match /category_images/{categoryId}/{fileName} {
      allow read: if true;
      allow write: if canManageCategories() || isSuperAdmin();
    }

    match /banner_images/{bannerId}/{fileName} {
      allow read: if true;
      allow write: if canManageBanners() || isSuperAdmin();
    }

    match /brand_images/{brandId}/{fileName} {
      allow read: if true;
      allow write: if canManageBrands() || isSuperAdmin();
    }

    match /profile_images/{profileId}/{fileName} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}